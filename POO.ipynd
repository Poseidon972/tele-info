"""###Méthodes de classe"""

class Moto:
    nb = 0

    def __init__(self):
        print("Création d'un objet de type moto")
        Moto.nb += 1
        print("Il y en a maintenant ", Moto.nb)

    @classmethod
    def get_nb(cls):
        return Moto.nb

print("Démarrage : Nombre de motos = ", Moto.get_nb())
moto1 = Moto()
print("Nombre de motos = ", Moto.get_nb())
moto2 = Moto()
print("Nombre de motos = ", Moto.get_nb())
