### Programmation Orientée Objet (POO) en Python

La programmation orientée objet (POO) permet de créer des entités (objets) que l'on peut manipuler.

Une classe regroupe des fonctions et des attributs qui définissent un objet. On appelle par ailleurs les fonctions d'une classe des " méthodes ".

Créons une classe Voiture avec 2 attributs, 4 méthodes et 1 constructeur :
"""

class Voiture:
  "Définition d'une voiture"
  # Attributs
  couleur = ""
  immatriculation = ""
  vitesse = 0
  # Méthodes
  def demarrer(self):
    self.demarree = True
    print("Moteur démarré")
    return
  def accelerer(self):
    if self.demarree == True:
      if self.vitesse <100 :
        self.vitesse += 10
      print(self.vitesse)
    else:
      print("la limite est de 100km/h")
    return
  def freiner(self):
    if self.demarree == True:
      if self.vitesse >0:
        self.vitesse -= 10
      print(self.vitesse)
    else:
      print("La voiture est a l'arrêt")
    return
  def arreter(self):
    if self.demarree == True:
      if self.vitesse == 0:
        self.demarree = False
      print("Moteur a l'arrêt")
    return
  # Constructeur
  def __init__(self):
    self.demarree = False
    print("Création d'un nouvel objet instance de la classe Voiture")

"""### Instanciation

Un objet est une instance d'une classe . On peut créer autant d'objets que l'on désire avec une classe .
"""

laTeslaDeMrX = Voiture()

"""### Définition des propriétés"""

laTeslaDeMrX.couleur = "rouge"
laTeslaDeMrX.immatriculation = "AB-123-CD"
print(laTeslaDeMrX.couleur)
print(laTeslaDeMrX.demarree)

"""### Appel d'une méthode"""

laTeslaDeMrX.demarrer()
laTeslaDeMrX.arreter()

